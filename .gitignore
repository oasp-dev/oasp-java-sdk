# Gradle build output - regenerated by `gradle build`, never hand-edited.
.gradle/
build/

# Compiled class files, in case anything is ever built outside of build/.
*.class

# IDE project files - everyone's IDE generates these locally; they don't
# belong in version control.
.idea/
*.iml
.vscode/
.settings/
.classpath
.project

# macOS Finder metadata.
.DS_Store
